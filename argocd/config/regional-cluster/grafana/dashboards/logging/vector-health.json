{
  "uid": "vector-health",
  "title": "Vector / Health",
  "tags": [
    "logging",
    "vector"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Thanos",
          "value": "Thanos"
        },
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(vector_build_info, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Vector Pods Running",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"vector\",phase=\"Running\",cluster=~\"$cluster\"}) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Events Sent / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_component_sent_events_total{component_type=\"loki\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Bytes Sent / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_component_sent_bytes_total{cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "HTTP Errors / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_http_client_responses_total{status=~\"4..|5..\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      }
    },
    {
      "type": "row",
      "title": "Throughput",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Events Sent to Loki (rate/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_component_sent_events_total{component_type=\"loki\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Events Received from Kubernetes (rate/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_component_received_events_total{component_id=\"kubernetes_logs\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Bytes Sent (rate/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_component_sent_bytes_total{cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Client RTT (p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vector_http_client_rtt_seconds_bucket{cluster=~\"$cluster\"}[5m])) by (le, cluster))",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      }
    },
    {
      "type": "row",
      "title": "Sink Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "HTTP Responses by Status",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(vector_http_client_responses_total{status=~\"2..\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}} 2xx"
        },
        {
          "expr": "sum(rate(vector_http_client_responses_total{status=~\"4..\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}} 4xx"
        },
        {
          "expr": "sum(rate(vector_http_client_responses_total{status=~\"5..\",cluster=~\"$cluster\"}[5m])) by (cluster)",
          "legendFormat": "{{cluster}} 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      }
    },
    {
      "type": "timeseries",
      "title": "Adaptive Concurrency Limit",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(vector_adaptive_concurrency_limit_bucket{cluster=~\"$cluster\"}) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      }
    },
    {
      "type": "row",
      "title": "Buffer",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Buffer Events (current)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(vector_buffer_events{cluster=~\"$cluster\"}) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "timeseries",
      "title": "Buffer Byte Size",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(vector_buffer_byte_size{cluster=~\"$cluster\"}) by (cluster)",
          "legendFormat": "{{cluster}} used"
        },
        {
          "expr": "sum(vector_buffer_max_byte_size{cluster=~\"$cluster\"}) by (cluster)",
          "legendFormat": "{{cluster}} max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 32
      }
    },
    {
      "type": "timeseries",
      "title": "Buffer Utilization (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(vector_buffer_byte_size{cluster=~\"$cluster\"}) by (cluster) / sum(vector_buffer_max_byte_size{cluster=~\"$cluster\"}) by (cluster) * 100",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 32
      }
    },
    {
      "type": "row",
      "title": "Source Lag",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Source Lag Time (p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(vector_source_lag_time_seconds_bucket{cluster=~\"$cluster\"}[5m])) by (le, cluster))",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 41
      }
    },
    {
      "type": "timeseries",
      "title": "Open Files",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(vector_open_files{cluster=~\"$cluster\"}) by (cluster)",
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 41
      }
    },
    {
      "type": "row",
      "title": "Resources",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 49
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"vector\",container=\"vector\",cluster=~\"$cluster\"}[5m])) by (cluster, pod)",
          "legendFormat": "{{cluster}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 50
      }
    },
    {
      "type": "timeseries",
      "title": "CPU % of Limit",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (cluster, pod) (rate(container_cpu_usage_seconds_total{namespace=\"vector\",container=\"vector\",cluster=~\"$cluster\"}[5m])) / sum by (cluster, pod) (kube_pod_container_resource_limits{namespace=\"vector\",container=\"vector\",resource=\"cpu\",cluster=~\"$cluster\"}) * 100",
          "legendFormat": "{{cluster}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 50
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"vector\",container=\"vector\",cluster=~\"$cluster\"}) by (cluster, pod)",
          "legendFormat": "{{cluster}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 50
      }
    },
    {
      "type": "timeseries",
      "title": "Memory % of Limit",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "sum by (cluster, pod) (container_memory_working_set_bytes{namespace=\"vector\",container=\"vector\",cluster=~\"$cluster\"}) / sum by (cluster, pod) (kube_pod_container_resource_limits{namespace=\"vector\",container=\"vector\",resource=\"memory\",cluster=~\"$cluster\"}) * 100",
          "legendFormat": "{{cluster}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 50
      }
    }
  ]
}