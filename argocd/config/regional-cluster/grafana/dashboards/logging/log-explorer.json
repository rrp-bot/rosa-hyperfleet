{
  "uid": "log-explorer",
  "title": "Loki / Log Explorer",
  "tags": [
    "logging",
    "loki",
    "explorer"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cluster_name",
        "label": "Cluster",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "Loki"
        },
        "query": {
          "label": "cluster_name",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "",
          "type": 1
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "Loki"
        },
        "query": {
          "label": "namespace",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{cluster_name=~\"$cluster_name\"}",
          "type": 1
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "Loki"
        },
        "query": {
          "label": "pod",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{cluster_name=~\"$cluster_name\", namespace=~\"$namespace\"}",
          "type": 1
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      },
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "Loki"
        },
        "query": {
          "label": "container",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{cluster_name=~\"$cluster_name\", namespace=~\"$namespace\", pod=~\"$pod\"}",
          "type": 1
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Log Volume by Cluster",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "sum by (cluster_name) (count_over_time({cluster_name=~\"$cluster_name\", namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} [$__interval]))",
          "legendFormat": "{{cluster_name}}",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ],
          "sortBy": "Total",
          "sortDesc": true
        }
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Log Volume by Namespace",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({cluster_name=~\"$cluster_name\", namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} [$__interval]))",
          "legendFormat": "{{namespace}}",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ],
          "sortBy": "Total",
          "sortDesc": true
        }
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Log Volume by Pod",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (pod) (count_over_time({cluster_name=~\"$cluster_name\", namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"} [$__interval])))",
          "legendFormat": "{{pod}}",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ],
          "sortBy": "Total",
          "sortDesc": true
        }
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 12
      }
    },
    {
      "type": "logs",
      "title": "Logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "expr": "{cluster_name=~\"$cluster_name\", namespace=~\"$namespace\", pod=~\"$pod\", container=~\"$container\"}",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 24
      }
    }
  ]
}